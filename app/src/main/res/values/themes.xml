<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.QL_Com_dao_BK" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_hover</item>
        <item name="colorOnPrimary">@color/surface</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_hover</item>
        <item name="colorOnSecondary">@color/surface</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/accent_hover</item>

        <!-- Background and Surface colors -->
        <item name="android:windowBackground">@color/bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorOnBackground">@color/text_main</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_muted</item>

        <!-- Error color -->
        <item name="colorError">@color/red</item>

        <!-- Global styles for components -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
    </style>

    <!-- Button Style: Rounded and Accent background -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="Widget.App.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="android:textColor">@color/accent</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.MediumComponent</item>
    </style>

    <!-- TextInputLayout Style: Outlined with Accent focus -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.SmallComponent</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/bg</item>
        <item name="itemIconTint">@color/accent_selector</item>
        <item name="itemTextColor">@color/accent_selector</item>
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="Theme.QL_Com_dao_BK.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />

    <style name="Theme.QL_Com_dao_BK.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <!-- Custom Card Style -->
    <style name="CustomCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
</resources>